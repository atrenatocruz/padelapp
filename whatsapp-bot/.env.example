# Supabase (service role — bypasses RLS, keep secret, never commit real values)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Multi-tenant: which club/organization this bot deployment serves — one
# bot process per organization. Find the id in the `organizations` table.
ORGANIZATION_ID=

# Base URL used to build mix links in WhatsApp messages. Defaults to
# https://alinho.pt if unset.
APP_URL=

# Where Baileys persists its login session between restarts.
# On Fly.io this must point inside the mounted volume (see fly.toml).
AUTH_DIR=./baileys-auth

# HTTP port for the Fly health check.
PORT=8080

# Optional: pair by phone number + code instead of scanning a QR in the
# logs. Format: country code + number, digits only (e.g. 351916376443).
# Leave empty to use the QR flow.
PAIRING_PHONE=
