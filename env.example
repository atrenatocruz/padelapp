# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# WhatsApp group bot config lives in whatsapp-bot/.env.example — it's a
# separate always-on Node process (deployed to Fly.io), not part of this
